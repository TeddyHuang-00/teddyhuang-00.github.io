---
import { getRelativeLocaleUrl } from "astro:i18n";
import PagefindConfig from "astro-pagefind/components/PagefindConfig.astro";
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import { SITE } from "@/config";
import { useTranslations } from "@/i18n/utils";
import Layout from "@/layouts/Layout.astro";
import Main from "@/layouts/Main.astro";

export const getStaticPaths = async () => {
  return Object.keys(SITE.locales).map((lang) => ({
    params: { locale: lang as keyof typeof SITE.locales },
  }));
};

const { locale } = Astro.params;
const localeString = useTranslations(locale);

const backUrl = SITE.showBackButton
  ? `${Astro.url.pathname}`
  : getRelativeLocaleUrl(locale, "/");
---

<Layout title={`${localeString("nav.search")} | ${localeString("site.title")}`}>
  <Header />
  <Main
    pageTitle={localeString("nav.search")}
    pageDesc={localeString("search.description")}
  >
    <div transition:persist data-backUrl={backUrl}>
      {
        import.meta.env.DEV && (
          <div class="p-4 mb-4 space-y-4 rounded bg-muted/75">
            <p>
              <strong>DEV mode Warning! </strong>You need to build the project
              at least once to see the search results during development.
            </p>
            <code class="block py-1 px-2 text-white bg-black rounded">
              bunx astro build
            </code>
          </div>
        )
      }
      <div id="pagefind-search">
        <PagefindConfig />
        <pagefind-input></pagefind-input>
        <pagefind-summary></pagefind-summary>
        <pagefind-results show-images="false"></pagefind-results>
      </div>
    </div>
  </Main>
  <Footer />
</Layout>

<style is:global>
  #pagefind-search {
    --pf-font: var(--font-mono);
    --pf-text: var(--foreground);
    --pf-text-secondary: color-mix(in srgb, var(--foreground) 70%, transparent);
    --pf-text-muted: color-mix(in srgb, var(--foreground) 55%, transparent);
    --pf-background: var(--background);
    --pf-border: var(--border);
    --pf-border-focus: var(--accent);
    --pf-hover: color-mix(in srgb, var(--muted) 75%, transparent);
    --pf-mark: var(--accent);
    --pf-outline-focus: var(--accent);
    --pf-outline-width: 1px;
    --pf-outline-offset: 1px;
    --pf-border-radius: 0.375rem;
    --pf-results-gap: 1rem;
  }

  #pagefind-search pagefind-summary,
  #pagefind-search pagefind-results {
    margin-top: 1rem;
  }

  #pagefind-search .pf-input-wrapper::before {
    background-color: var(--foreground);
  }

  #pagefind-search .pf-input {
    font-weight: 400;
    border: 1px solid var(--border);
  }

  #pagefind-search .pf-input:focus-visible,
  #pagefind-search .pf-result-card:has(.pf-result-link:focus-visible) {
    box-shadow: 0 0 0 1px var(--accent);
  }

  #pagefind-search .pf-result-link {
    color: var(--accent);
    outline-offset: 1px;
    outline-color: var(--accent);
  }

  #pagefind-search .pf-result-link:hover {
    text-decoration-line: none;
  }

  #pagefind-search .pf-input-clear:focus-visible,
  #pagefind-search .pf-result-link:focus-visible {
    outline-width: 2px;
    outline-style: dashed;
  }

  #pagefind-search .pf-results {
    margin-top: 1rem;
  }

  #pagefind-search .pf-result:last-of-type {
    border-bottom: 0;
  }

  #pagefind-search .pf-subresults .pf-result-link::before {
    font-family: system-ui;
  }
</style>
